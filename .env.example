# Copy this file to .env and fill in real values. Never commit the real .env.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com

# Leave DATABASE_URL unset locally to use sqlite automatically.
# On Render, set this to the "Internal Database URL" from your Postgres instance.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Groq (get a free key at console.groq.com)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-120b

# Vector store: "chroma" for local dev, "pgvector" once deployed on Render
VECTOR_STORE_BACKEND=chroma
CHROMA_PERSIST_DIR=./chroma_store
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
